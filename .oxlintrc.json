{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error"
  },
  "overrides": [
    {
      "files": ["extensions/*.ts", "extensions/**/*.ts"]
    }
  ],
  "rules": {
    "eslint/no-unused-vars": "error",
    "typescript/no-explicit-any": "error"
  },
  "env": {
    "builtin": true
  },
  "options": {
    "typeAware": true,
    "typeCheck": true
  }
}
